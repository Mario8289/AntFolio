---
import { Sun, Moon, Menu, X, Search } from "lucide-react";

interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;

const navItems = [
  { name: "Posts", id: "posts", href: "/posts" },
  { name: "Projects", id: "projects", href: "/projects" },
  { name: "Tips", id: "tips", href: "/tips" },
  { name: "About", id: "about", href: "/about" },
];
---

<header class="py-8 px-4 sm:px-8 max-w-4xl mx-auto w-full">
  <div class="flex justify-between items-center">
    <a 
      href="/" 
      class="text-2xl font-mono font-bold tracking-tighter hover:text-accent transition-colors"
    >
      ASTRO<span class="text-accent underline decoration-2 underline-offset-4">PAPER</span>
    </a>

    <nav class="hidden sm:flex items-center space-x-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`nav-link ${currentPage === item.id ? "text-accent underline underline-offset-4" : ""}`}
        >
          {item.name}
        </a>
      ))}
      <button class="nav-link p-2" aria-label="Search">
        <Search size={18} />
      </button>
      <button
        id="theme-toggle"
        class="p-2 hover:text-accent transition-colors"
        aria-label="Toggle dark mode"
      >
        <span class="dark:hidden"><Moon size={20} /></span>
        <span class="hidden dark:block"><Sun size={20} /></span>
      </button>
    </nav>

    <div class="flex sm:hidden items-center space-x-2">
      <button id="mobile-theme-toggle" class="p-2" aria-label="Toggle dark mode">
        <span class="dark:hidden"><Moon size={20} /></span>
        <span class="hidden dark:block"><Sun size={20} /></span>
      </button>
      <button id="menu-toggle" class="p-2" aria-label="Toggle menu">
        <span id="menu-icon-open"><Menu size={24} /></span>
        <span id="menu-icon-close" class="hidden"><X size={24} /></span>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden mt-4 flex-col space-y-4 border-t border-dashed border-gray-300 dark:border-gray-700 pt-4"
  >
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`nav-link text-left py-2 ${currentPage === item.id ? "text-accent" : ""}`}
      >
        {item.name}
      </a>
    ))}
    <button class="nav-link text-left py-2 flex items-center">
      <Search size={18} class="mr-2" /> Search
    </button>
  </nav>
</header>

<script>
  // Mobile menu toggle logic
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
    menuIconOpen?.classList.toggle('hidden');
    menuIconClose?.classList.toggle('hidden');
  });

  // Theme toggle logic
  const handleThemeToggle = () => {
    const element = document.documentElement;
    const isDark = element.getAttribute('data-theme') === 'dark';
    const newTheme = isDark ? 'light' : 'dark';
    
    element.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
  };

  document.getElementById('theme-toggle')?.addEventListener('click', handleThemeToggle);
  document.getElementById('mobile-theme-toggle')?.addEventListener('click', handleThemeToggle);
</script>
