---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title?: string;
  description?: string;
  currentPage?: string;
}

const { title, description, currentPage } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} />
    <script is:inline>
      // Initialize theme before rendering to avoid flash
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
	</head>
	<body class="min-h-screen flex flex-col font-sans selection:bg-accent selection:text-white">
    <Header currentPage={currentPage} />
    <main class="flex-grow px-4 sm:px-8 max-w-4xl mx-auto w-full py-8">
      <slot />
    </main>
    <Footer />
	</body>
</html>
