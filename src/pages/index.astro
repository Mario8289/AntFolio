---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, Rss } from 'lucide-react';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const recentPosts = sortedPosts.slice(0, 2);

const FEATURED_PROJECTS = [
  {
    id: "antfolio",
    title: "AntFolio",
    description: "A minimal, terminal-inspired personal portfolio and digital garden.",
    link: "https://github.com/Mario8289/AntFolio",
    github: "https://github.com/Mario8289/AntFolio",
    tags: ["Astro", "TailwindCSS", "TypeScript"]
  }
];
---

<Layout title="Home" currentPage="home">
  <section class="space-y-12">
    <section>
      <h1 class="text-4xl sm:text-5xl mb-6 tracking-tighter leading-tight">
        Senior Analytics <span class="text-accent italic">Engineer</span>. <br/>
        Developer. <span class="text-accent underline underline-offset-8">Python Maximalist</span>.
      </h1>
      
      <div class="mb-8 font-mono text-sm opacity-90 overflow-x-auto">
        <div class="text-accent mb-1">$ whoami</div>
        <div class="whitespace-pre">┌─────────────────────────────────────────────────────────────┐
│ "Built for trails, wired for sci-fi, can't walk past a      │
│  problem, emotionally hostage to Arsenal."                  │
└─────────────────────────────────────────────────────────────┘</div>
      </div>

      <p class="max-w-2xl text-lg leading-relaxed opacity-80 mb-6">
        I am a results-driven <span class="text-accent font-medium">data science</span> and <span class="text-accent font-medium">business intelligence leader</span> with over 10 years of experience delivering production-ready software, scalable data workflows, and business automations. 
        <br/><br/>
        This space serves as my digital garden. I am going to start using this to upload anything I find interesting—from <span class="text-accent font-medium">investment ideas</span> to replicating features my favorite apps have moved behind paywalls.
      </p>
      
      <button class="inline-flex items-center space-x-2 text-sm font-mono opacity-60 hover:opacity-100 transition-opacity">
        <Rss size={14} /> <span>Atomic RSS Feed</span>
      </button>
    </section>

    <section>
      <div class="flex justify-between items-end mb-6">
        <h2 class="text-2xl font-mono">Recent Posts</h2>
        <a 
          href="/posts"
          class="text-sm font-mono text-accent hover:underline flex items-center"
        >
          All Posts <ArrowRight size={14} class="ml-1" />
        </a>
      </div>
      <ul class="space-y-0 p-0">
        {recentPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </ul>
    </section>

    <section>
      <div class="flex justify-between items-end mb-6">
        <h2 class="text-2xl font-mono">Featured Projects</h2>
        <a 
          href="/projects"
          class="text-sm font-mono text-accent hover:underline flex items-center"
        >
          View All <ArrowRight size={14} class="ml-1" />
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {FEATURED_PROJECTS.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  </section>
</Layout>
