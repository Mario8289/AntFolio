---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, Rss } from 'lucide-react';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const recentPosts = sortedPosts.slice(0, 2);

const FEATURED_PROJECTS = [
  {
    id: "paper-v5",
    title: "Astro Paper v5",
    description: "A minimalist, responsive, accessible and SEO-friendly Astro blog theme.",
    link: "https://astro-paper.pages.dev/",
    github: "https://github.com/satnaing/astro-paper",
    tags: ["Astro", "TailwindCSS", "TypeScript"]
  },
  {
    id: "nexus-os",
    title: "Nexus OS",
    description: "A conceptual operating system interface built entirely with React and Framer Motion.",
    link: "#",
    tags: ["React", "Motion", "UX"]
  }
];
---

<Layout title="Home" currentPage="home">
  <section class="space-y-12">
    <section>
      <h1 class="text-4xl sm:text-5xl mb-6 tracking-tighter leading-tight">
        Senior Web <span class="text-accent italic">Architect</span>. <br/>
        Developer. <span class="text-accent underline underline-offset-8">Minimalist</span>.
      </h1>
      
      <div class="card mb-8 bg-accent/5 border-accent/20">
        <p class="font-mono text-sm leading-relaxed italic opacity-80">
          "I have a strong affinity for <code class="text-accent">flex-grow</code>... <br/>
          ...because I'm always looking to expand my horizons."
        </p>
      </div>

      <p class="max-w-2xl text-lg leading-relaxed opacity-80 mb-6">
        Technically authoritative, but I try not to take my stack traces too seriously. This space serves as my digital garden—a collection of <span class="accent-text">architectural patterns</span>, mid-level deep dives, and side-projects built with the <span class="accent-text">Electric Purple</span> aesthetic.
      </p>
      
      <button class="inline-flex items-center space-x-2 text-sm font-mono opacity-60 hover:opacity-100 transition-opacity">
        <Rss size={14} /> <span>Atomic RSS Feed</span>
      </button>
    </section>

    <section>
      <div class="flex justify-between items-end mb-6">
        <h2 class="text-2xl font-mono">Recent Posts</h2>
        <a 
          href="/posts"
          class="text-sm font-mono text-accent hover:underline flex items-center"
        >
          All Posts <ArrowRight size={14} class="ml-1" />
        </a>
      </div>
      <ul class="space-y-0 p-0">
        {recentPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </ul>
    </section>

    <section>
      <div class="flex justify-between items-end mb-6">
        <h2 class="text-2xl font-mono">Featured Projects</h2>
        <a 
          href="/projects"
          class="text-sm font-mono text-accent hover:underline flex items-center"
        >
          View All <ArrowRight size={14} class="ml-1" />
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {FEATURED_PROJECTS.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  </section>
</Layout>
