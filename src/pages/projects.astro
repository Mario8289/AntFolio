---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const PROJECTS = [
  {
    id: "paper-v5",
    title: "Astro Paper v5",
    description: "A minimalist, responsive, accessible and SEO-friendly Astro blog theme.",
    link: "https://astro-paper.pages.dev/",
    github: "https://github.com/satnaing/astro-paper",
    tags: ["Astro", "TailwindCSS", "TypeScript"]
  },
  {
    id: "nexus-os",
    title: "Nexus OS",
    description: "A conceptual operating system interface built entirely with React and Framer Motion.",
    link: "#",
    tags: ["React", "Motion", "UX"]
  },
  {
    id: "quant-vault",
    title: "QuantVault",
    description: "Specialized tool for quantitative analysts to track and backtest trading strategies.",
    link: "#",
    tags: ["D3.js", "Financial Data", "TypeScript"]
  }
];
---

<Layout title="Projects" description="Gallery of my recent projects." currentPage="projects">
  <h1 class="text-3xl font-mono mb-2 uppercase tracking-tight">Projects Gallery</h1>
  <p class="opacity-60 mb-12">Some of the stuff I've built or worked on.</p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {PROJECTS.map((project) => (
      <ProjectCard project={project} />
    ))}
  </div>
</Layout>
